<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
    Dragon Tamagotchi Financier
    À inclure DANS coffresDisplayContainer, juste après coffresCardsContainer
    dans UserDashboardAccountsSection.fxml :

    <fx:include fx:id="dragonView" source="DragonView.fxml"/>

    Le contrôleur sera injecté automatiquement comme :  DragonController dragonViewController;
-->
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nexora.bank.controllers.DragonController"
      fx:id="dragonRoot"
      spacing="0"
      style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e1b4b);
             -fx-background-radius: 20;
             -fx-border-color: #6366f1;
             -fx-border-width: 1.5;
             -fx-border-radius: 20;
             -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.4), 20, 0, 0, 4);">

    <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
    <HBox spacing="12" alignment="CENTER_LEFT"
          style="-fx-background-color: rgba(99,102,241,0.15);
                 -fx-background-radius: 20 20 0 0;
                 -fx-padding: 14 20 14 20;">
        <StackPane style="-fx-background-color: rgba(99,102,241,0.3);
                          -fx-background-radius: 10;
                          -fx-min-width: 36; -fx-min-height: 36;">
            <FontIcon iconLiteral="fas-dragon" style="-fx-icon-size: 16; -fx-icon-color: #a5b4fc;"/>
        </StackPane>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Draco — Ton Compagnon Financier"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #e0e7ff;"/>
            <Label text="Il reflète l'état de ton épargne en temps réel"
                   style="-fx-font-size: 11px; -fx-text-fill: #818cf8;"/>
        </VBox>
    </HBox>

    <!-- ══ BODY ════════════════════════════════════════════════════════ -->
    <HBox spacing="0">

        <!-- ── COLONNE GAUCHE : Avatar Héros ──────────────────────────── -->
        <VBox spacing="16" alignment="CENTER"
              style="-fx-padding: 24 20 24 24; -fx-min-width: 200;"
              fx:id="dragonContainer">

            <!-- StackPane pour l'avatar : fond glowing + ImageView -->
            <StackPane fx:id="avatarPane"
                       onMouseClicked="#handleParler"
                       style="-fx-background-color: radial-gradient(center 50% 50%, radius 60%, rgba(99,102,241,0.25), transparent);
                              -fx-background-radius: 50%;
                              -fx-padding: 8;
                              -fx-cursor: hand;">
                <ImageView fx:id="imgAvatar"
                           fitWidth="96"
                           fitHeight="96"
                           preserveRatio="true"
                           smooth="true"/>
                <!-- Label emoji caché — gardé pour compatibilité animation (opacity 0) -->
                <Label fx:id="lblDragonEmoji" text=""
                       style="-fx-font-size: 1px; -fx-opacity: 0;"/>
            </StackPane>

            <!-- Niveau -->
            <Label fx:id="lblDragonNiveau" text="Bébé Héros"
                   style="-fx-font-size: 15px; -fx-font-weight: bold;
                          -fx-text-fill: #c7d2fe;"/>

            <!-- Humeur -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Humeur :" style="-fx-font-size: 11px; -fx-text-fill: #818cf8;"/>
                <Label fx:id="lblDragonHumeur" text="😄 Heureux"
                       style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #22c55e;"/>
            </HBox>

            <!-- Bouton Parler -->
            <Button fx:id="btnParler" onAction="#handleParler"
                    style="-fx-background-color: #6366f1;
                           -fx-text-fill: white;
                           -fx-font-size: 12px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 20;
                           -fx-padding: 8 20;
                           -fx-cursor: hand;
                           -fx-effect: dropshadow(gaussian, rgba(99,102,241,0.5), 8, 0, 0, 2);">
                <graphic>
                    <HBox spacing="6" alignment="CENTER">
                        <FontIcon iconLiteral="fas-comment-dots"
                                  style="-fx-icon-size: 13; -fx-icon-color: white;"/>
                        <Label text="Parler" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>
                </graphic>
            </Button>

            <!-- Bouton Nourrir -->
            <Button fx:id="btnNourrir" onAction="#handleNourrir"
                    style="-fx-background-color: transparent;
                           -fx-border-color: #f59e0b;
                           -fx-border-radius: 20;
                           -fx-border-width: 1.5;
                           -fx-text-fill: #f59e0b;
                           -fx-font-size: 12px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 20;
                           -fx-padding: 7 18;
                           -fx-cursor: hand;">
                <graphic>
                    <HBox spacing="6" alignment="CENTER">
                        <FontIcon iconLiteral="fas-coins"
                                  style="-fx-icon-size: 13; -fx-icon-color: #f59e0b;"/>
                        <Label text="Nourrir" style="-fx-text-fill: #f59e0b; -fx-font-weight: bold;"/>
                    </HBox>
                </graphic>
            </Button>

            <!-- Panel Nourrir (caché par défaut) -->
            <VBox fx:id="nourirPanel" spacing="10" visible="false" managed="false"
                  style="-fx-background-color: rgba(245,158,11,0.1);
                         -fx-border-color: rgba(245,158,11,0.4);
                         -fx-border-radius: 12;
                         -fx-background-radius: 12;
                         -fx-padding: 12;">
                <Label text="💰 Montant à transférer (DT)"
                       style="-fx-font-size: 11px; -fx-text-fill: #fbbf24;"/>
                <TextField fx:id="txtMontantNourrir"
                           promptText="ex: 50"
                           style="-fx-background-color: rgba(255,255,255,0.08);
                                  -fx-text-fill: white;
                                  -fx-prompt-text-fill: #6b7280;
                                  -fx-border-color: rgba(245,158,11,0.5);
                                  -fx-border-radius: 8;
                                  -fx-background-radius: 8;
                                  -fx-padding: 7 12;"/>
                <HBox spacing="8">
                    <Button fx:id="btnConfirmerNourrir" onAction="#handleConfirmerNourrir"
                            HBox.hgrow="ALWAYS"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #f59e0b;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;
                                   -fx-padding: 7 0;
                                   -fx-cursor: hand;">
                        <graphic>
                            <HBox spacing="5" alignment="CENTER">
                                <FontIcon iconLiteral="fas-check"
                                          style="-fx-icon-size: 11; -fx-icon-color: white;"/>
                                <Label text="Confirmer" style="-fx-text-fill: white;"/>
                            </HBox>
                        </graphic>
                    </Button>
                    <Button fx:id="btnAnnulerNourrir" onAction="#handleAnnulerNourrir"
                            style="-fx-background-color: transparent;
                                   -fx-border-color: #6b7280;
                                   -fx-border-radius: 8;
                                   -fx-text-fill: #9ca3af;
                                   -fx-padding: 7 12;
                                   -fx-cursor: hand;">
                        <graphic>
                            <FontIcon iconLiteral="fas-times"
                                      style="-fx-icon-size: 11; -fx-icon-color: #9ca3af;"/>
                        </graphic>
                    </Button>
                </HBox>
            </VBox>

        </VBox>

        <!-- Séparateur vertical -->
        <VBox style="-fx-background-color: rgba(99,102,241,0.2); -fx-min-width: 1;"/>

        <!-- ── COLONNE DROITE : Infos + Message ────────────────────── -->
        <VBox spacing="16" HBox.hgrow="ALWAYS"
              style="-fx-padding: 24 24 24 20;">

            <!-- ── Progression coffre ─────────────────────────────── -->
            <VBox spacing="8"
                  style="-fx-background-color: rgba(255,255,255,0.04);
                         -fx-border-color: rgba(99,102,241,0.25);
                         -fx-border-radius: 12;
                         -fx-background-radius: 12;
                         -fx-padding: 14;">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <FontIcon iconLiteral="fas-piggy-bank"
                              style="-fx-icon-size: 13; -fx-icon-color: #818cf8;"/>
                    <Label fx:id="lblNomCoffre" text="Mon Coffre"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #c7d2fe;"/>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblProgressionPct" text="0%"
                           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #a5b4fc;"/>
                </HBox>
                <ProgressBar fx:id="progressBar" progress="0.0"
                             maxWidth="1.7976931348623157E308"
                             style="-fx-accent: #6366f1;
                                    -fx-background-color: rgba(99,102,241,0.15);
                                    -fx-background-radius: 6;
                                    -fx-pref-height: 10;"/>
                <Label fx:id="lblMontantCoffre" text="0.00 / 0.00 DT"
                       style="-fx-font-size: 11px; -fx-text-fill: #6b7280;"/>
            </VBox>

            <!-- ── Stats compte ───────────────────────────────────── -->
            <HBox spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(34,197,94,0.08);
                             -fx-border-color: rgba(34,197,94,0.2);
                             -fx-border-radius: 10;
                             -fx-background-radius: 10;
                             -fx-padding: 10 14;">
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="fas-wallet"
                                  style="-fx-icon-size: 11; -fx-icon-color: #22c55e;"/>
                        <Label text="Solde" style="-fx-font-size: 10px; -fx-text-fill: #6b7280;"/>
                    </HBox>
                    <Label fx:id="lblSolde" text="0.00 DT"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #22c55e;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: rgba(249,115,22,0.08);
                             -fx-border-color: rgba(249,115,22,0.2);
                             -fx-border-radius: 10;
                             -fx-background-radius: 10;
                             -fx-padding: 10 14;">
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <FontIcon iconLiteral="fas-arrow-down"
                                  style="-fx-icon-size: 11; -fx-icon-color: #f97316;"/>
                        <Label text="Dépenses (1 mois)"
                               style="-fx-font-size: 10px; -fx-text-fill: #6b7280;"/>
                    </HBox>
                    <Label fx:id="lblDepenses" text="0.00 DT"
                           style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #f97316;"/>
                </VBox>
            </HBox>

            <!-- ── Message du dragon ──────────────────────────────── -->
            <VBox spacing="8"
                  style="-fx-background-color: rgba(99,102,241,0.08);
                         -fx-border-color: rgba(99,102,241,0.3);
                         -fx-border-radius: 12;
                         -fx-background-radius: 12;
                         -fx-padding: 14;">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <FontIcon iconLiteral="fas-comment"
                              style="-fx-icon-size: 12; -fx-icon-color: #818cf8;"/>
                    <Label text="Draco dit :"
                           style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #818cf8;"/>
                </HBox>
                <Label fx:id="lblMessageDragon"
                       text="Chargement du message..."
                       wrapText="true"
                       style="-fx-font-size: 12px;
                              -fx-text-fill: #e0e7ff;
                              -fx-font-style: italic;"/>
            </VBox>

            <!-- ── Conseil financier ──────────────────────────────── -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(245,158,11,0.08);
                         -fx-border-color: rgba(245,158,11,0.25);
                         -fx-border-radius: 10;
                         -fx-background-radius: 10;
                         -fx-padding: 12 14;">
                <Label text="💡" style="-fx-font-size: 16px;"/>
                <Label fx:id="lblConseil"
                       text="Épargner régulièrement aide à atteindre tes objectifs plus vite."
                       wrapText="true"
                       HBox.hgrow="ALWAYS"
                       style="-fx-font-size: 11px; -fx-text-fill: #fbbf24;"/>
            </HBox>

        </VBox>
    </HBox>

</VBox>
