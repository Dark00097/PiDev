<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<!--
    ═══════════════════════════════════════════════════════════════════
    RoueFortune.fxml  —  NEXORA BANK  (Gray Light theme)
    Palette :
      Fond      : #F3F4F6 (gray-100) → #EBEDF0 (gray-150) → #E5E7EB (gray-200)
      Surface   : #FFFFFF / #F9FAFB (gray-50)
      Bords     : #D1D5DB (gray-300) / #E5E7EB (gray-200)
      Texte     : #1F2937 (foncé) / #6B7280 (gray-500) / #9CA3AF (gray-400)
      Accents   : Teal #00B4A0/#009485 · Gold #F4C430/#D4A82A · Rouge #EF4444
    ═══════════════════════════════════════════════════════════════════
-->
<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.nexora.bank.controllers.RoueFortuneController"
           prefWidth="900" prefHeight="640"
           style="-fx-background-color:linear-gradient(to bottom right,#F3F4F6,#EBEDF0,#E5E7EB);">

    <!-- Fond décoratif subtil -->
    <VBox style="-fx-background-color:transparent;" mouseTransparent="true" alignment="TOP_CENTER">
        <Label text="✦  ✧    ✦       ✧  ✦    ✧       ✦  ✧  ✦  ✧    ✦       ✧  ✦"
               style="-fx-text-fill:rgba(0,180,160,0.07); -fx-font-size:20px; -fx-padding:8 0 0 0;"/>
        <Label text="  ✧    ✦   ✦       ✧  ✦    ✧       ✦  ✧  ✦  ✧    ✦"
               style="-fx-text-fill:rgba(0,180,160,0.05); -fx-font-size:16px;"/>
    </VBox>

    <VBox spacing="0" alignment="TOP_CENTER">

        <!-- ══ TITLE BAR ══════════════════════════════════════════════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color:#FFFFFF;
                     -fx-padding:15 22 15 22;
                     -fx-border-color:#D1D5DB transparent transparent transparent;
                     -fx-border-width:0 0 1 0;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">

            <StackPane style="-fx-background-color:rgba(0,180,160,0.12);
                              -fx-background-radius:10; -fx-padding:9;
                              -fx-border-color:rgba(0,180,160,0.30); -fx-border-radius:10;">
                <FontIcon iconLiteral="fas-dharmachakra"
                          style="-fx-fill:#009485; -fx-icon-size:22;"/>
            </StackPane>

            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🎡  Wheel of Fortune"
                           style="-fx-font-size:20px; -fx-font-weight:900; -fx-text-fill:#1F2937;"/>
                    <Label fx:id="lblBadgeStatut" text="⏳  Vérification..."
                           style="-fx-background-color:rgba(244,196,48,0.15);
                                  -fx-text-fill:#D4A82A; -fx-background-radius:20;
                                  -fx-padding:3 12; -fx-font-size:11px; -fx-font-weight:700;
                                  -fx-border-color:rgba(212,168,42,0.35); -fx-border-radius:20;"/>
                </HBox>
                <Label text="NEXORA BANK  ·  Analyse comportement financier mensuel"
                       style="-fx-font-size:11px; -fx-text-fill:#9CA3AF;"/>
            </VBox>

            <Button fx:id="btnFermer" onAction="#fermerFenetre"
                    style="-fx-background-color:rgba(239,68,68,0.08);
                           -fx-background-radius:8; -fx-border-color:rgba(239,68,68,0.25);
                           -fx-border-radius:8; -fx-cursor:hand; -fx-padding:8 14;">
                <graphic>
                    <HBox spacing="6" alignment="CENTER">
                        <FontIcon iconLiteral="fas-times" style="-fx-fill:#EF4444; -fx-icon-size:11;"/>
                        <Label text="Fermer" style="-fx-text-fill:#EF4444; -fx-font-size:11px;"/>
                    </HBox>
                </graphic>
            </Button>
        </HBox>

        <!-- ══ CORPS ══════════════════════════════════════════════════════════ -->
        <HBox spacing="0" VBox.vgrow="ALWAYS">

            <!-- ════ GAUCHE : ROUE ════════════════════════════════════════════ -->
            <VBox alignment="CENTER" spacing="18" prefWidth="430"
                  style="-fx-padding:22 26 26 26;
                         -fx-background-color:#FCFCFD;
                         -fx-border-color:#E5E7EB transparent;
                         -fx-border-width:0 1 0 0;">

                <!-- Canvas glow teal doux -->
                <StackPane fx:id="rouePaneContainer" alignment="CENTER"
                           style="-fx-effect:dropshadow(gaussian,rgba(0,180,160,0.30),35,0.20,0,0);">
                    <Canvas fx:id="rouCanvas" width="330" height="330"/>
                </StackPane>

                <Label fx:id="lblRoueStatut" text="🔍  Analyse en cours..."
                       wrapText="true" maxWidth="350"
                       style="-fx-text-fill:#6B7280; -fx-font-size:12px;
                              -fx-alignment:center; -fx-text-alignment:center;"/>

                <!-- Bouton désactivé par défaut -->
                <Button fx:id="btnTourner" text="🎡  Lancer la roue"
                        onAction="#lancerRoue" maxWidth="270" disable="true"
                        style="-fx-background-color:#E5E7EB;
                               -fx-text-fill:#9CA3AF;
                               -fx-font-weight:bold; -fx-font-size:14px;
                               -fx-background-radius:28; -fx-padding:14 34;
                               -fx-cursor:hand;
                               -fx-border-color:#D1D5DB; -fx-border-radius:28;"/>

                <Label fx:id="lblRoueMessage" text=""
                       wrapText="true" maxWidth="360"
                       style="-fx-font-size:15px; -fx-font-weight:900;
                              -fx-text-fill:#D4A82A; -fx-text-alignment:center;
                              -fx-alignment:center;
                              -fx-effect:dropshadow(gaussian,rgba(212,168,42,0.40),10,0.3,0,0);"/>

                <!-- BONUS 50 DT -->
                <VBox fx:id="panelBonus" spacing="6" alignment="CENTER"
                      visible="false" managed="false"
                      style="-fx-background-color:linear-gradient(to bottom right,rgba(34,197,94,0.12),rgba(16,185,129,0.08));
                             -fx-border-color:#22C55E; -fx-border-radius:14;
                             -fx-background-radius:14; -fx-padding:14 22;">
                    <Label text="🎁  RÉCOMPENSE DÉBLOQUÉE !"
                           style="-fx-font-size:14px; -fx-font-weight:900; -fx-text-fill:#16A34A;"/>
                    <Label text="+50 DT automatiquement crédités sur ton compte !"
                           style="-fx-font-size:12px; -fx-text-fill:#1F2937;"/>
                </VBox>
            </VBox>

            <!-- ════ DROITE : CONDITIONS + BARRE + REFUS ══════════════════════ -->
            <VBox HBox.hgrow="ALWAYS" style="-fx-background-color:#F9FAFB;">
                <ScrollPane fitToWidth="true" fitToHeight="true"
                            style="-fx-background:transparent; -fx-background-color:transparent;">
                    <VBox spacing="14" style="-fx-padding:22 22 22 20;">

                        <!-- ─── CONDITIONS ────────────────────────────────── -->
                        <VBox spacing="9">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <FontIcon iconLiteral="fas-clipboard-check"
                                          style="-fx-fill:#009485; -fx-icon-size:14;"/>
                                <Label text="Conditions d'éligibilité"
                                       style="-fx-font-size:13px; -fx-font-weight:800;
                                              -fx-text-fill:#1F2937;"/>
                            </HBox>

                            <!-- Condition 1 : Solde -->
                            <HBox fx:id="cardCondSolde" spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color:#FFFFFF;
                                         -fx-border-color:#E5E7EB;
                                         -fx-border-radius:12; -fx-background-radius:12;
                                         -fx-padding:11 14;
                                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),6,0,0,1);">
                                <StackPane style="-fx-background-color:rgba(0,180,160,0.10);
                                                  -fx-background-radius:8; -fx-padding:6;">
                                    <FontIcon iconLiteral="fas-wallet"
                                              style="-fx-fill:#009485; -fx-icon-size:13;"/>
                                </StackPane>
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label fx:id="lblCondSolde" text="Solde toujours positif"
                                           style="-fx-font-size:12px; -fx-font-weight:700;
                                                  -fx-text-fill:#1F2937;"/>
                                    <Label text="Aucun soldeApres négatif ce mois"
                                           style="-fx-font-size:10px; -fx-text-fill:#9CA3AF;"/>
                                </VBox>
                                <Label fx:id="iconCondSolde" text="✅" style="-fx-font-size:14px;"/>
                            </HBox>

                            <!-- Condition 2 : Budget global ≤ 80% revenus -->
                            <HBox fx:id="cardCondBudget" spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color:#FFFFFF;
                                         -fx-border-color:#E5E7EB;
                                         -fx-border-radius:12; -fx-background-radius:12;
                                         -fx-padding:11 14;
                                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),6,0,0,1);">
                                <StackPane style="-fx-background-color:rgba(244,196,48,0.12);
                                                  -fx-background-radius:8; -fx-padding:6;">
                                    <FontIcon iconLiteral="fas-chart-pie"
                                              style="-fx-fill:#D4A82A; -fx-icon-size:13;"/>
                                </StackPane>
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label fx:id="lblCondBudget" text="Budget mensuel respecté"
                                           style="-fx-font-size:12px; -fx-font-weight:700;
                                                  -fx-text-fill:#1F2937;"/>
                                    <Label text="Dépenses totales ≤ 80% du revenu mensuel"
                                           style="-fx-font-size:10px; -fx-text-fill:#9CA3AF;"/>
                                </VBox>
                                <Label fx:id="iconCondBudget" text="✅" style="-fx-font-size:14px;"/>
                            </HBox>

                            <!-- Condition 3 : Épargne -->
                            <HBox fx:id="cardCondEpargne" spacing="12" alignment="CENTER_LEFT"
                                  style="-fx-background-color:#FFFFFF;
                                         -fx-border-color:#E5E7EB;
                                         -fx-border-radius:12; -fx-background-radius:12;
                                         -fx-padding:11 14;
                                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),6,0,0,1);">
                                <StackPane style="-fx-background-color:rgba(0,180,160,0.10);
                                                  -fx-background-radius:8; -fx-padding:6;">
                                    <FontIcon iconLiteral="fas-piggy-bank"
                                              style="-fx-fill:#009485; -fx-icon-size:13;"/>
                                </StackPane>
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label fx:id="lblCondEpargne" text="Épargne mensuelle active"
                                           style="-fx-font-size:12px; -fx-font-weight:700;
                                                  -fx-text-fill:#1F2937;"/>
                                    <Label text="Au moins 1 virement vers Coffre Virtuel"
                                           style="-fx-font-size:10px; -fx-text-fill:#9CA3AF;"/>
                                </VBox>
                                <Label fx:id="iconCondEpargne" text="✅" style="-fx-font-size:14px;"/>
                            </HBox>

                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <FontIcon iconLiteral="fas-info-circle"
                                          style="-fx-fill:#D4A82A; -fx-icon-size:10;"/>
                                <Label text="Les 3 conditions sont obligatoires pour jouer"
                                       style="-fx-font-size:10px; -fx-font-style:italic;
                                              -fx-text-fill:#6B7280;"/>
                            </HBox>
                        </VBox>

                        <!-- ─── BARRE POINTS ───────────────────────────────── -->
                        <VBox fx:id="panelBarre" spacing="8"
                              style="-fx-background-color:#FFFFFF;
                                     -fx-border-color:#E5E7EB;
                                     -fx-border-radius:14; -fx-background-radius:14;
                                     -fx-padding:14 16;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),6,0,0,1);">
                            <HBox alignment="CENTER_LEFT" spacing="7">
                                <FontIcon iconLiteral="fas-star"
                                          style="-fx-fill:#D4A82A; -fx-icon-size:13;"/>
                                <Label text="Tes points NEXORA"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-font-size:12px; -fx-font-weight:800;
                                              -fx-text-fill:#1F2937;"/>
                                <Label fx:id="lblPoints" text="0 / 100 pts  —  0%"
                                       style="-fx-font-size:12px; -fx-font-weight:800;
                                              -fx-text-fill:#D4A82A;"/>
                            </HBox>
                            <ProgressBar fx:id="progressPoints" progress="0"
                                         maxWidth="1.7976931348623157E308"
                                         style="-fx-accent:#F4C430;
                                                -fx-background-color:#E5E7EB;
                                                -fx-background-radius:6; -fx-pref-height:8;"/>
                            <Label fx:id="lblProgressText" text="Vérification des points en cours..."
                                   style="-fx-font-size:10px; -fx-text-fill:#6B7280;"/>
                        </VBox>

                        <!-- ─── PANEL REFUS ─────────────────────────────────── -->
                        <VBox fx:id="panelRefus" spacing="10" visible="false" managed="false"
                              style="-fx-background-color:#FFFFFF;
                                     -fx-border-color:#FECACA;
                                     -fx-border-radius:14; -fx-background-radius:14;
                                     -fx-padding:14 16;
                                     -fx-effect:dropshadow(gaussian,rgba(239,68,68,0.10),8,0,0,2);">
                            <HBox spacing="8" alignment="CENTER_LEFT">
                                <FontIcon iconLiteral="fas-lock"
                                          style="-fx-fill:#EF4444; -fx-icon-size:14;"/>
                                <Label text="Accès refusé — Voici pourquoi et comment débloquer"
                                       style="-fx-font-size:13px; -fx-font-weight:800;
                                              -fx-text-fill:#DC2626;"/>
                            </HBox>

                            <Label fx:id="lblRefusRaison" text="" wrapText="true"
                                   style="-fx-font-size:12px; -fx-text-fill:#374151;
                                          -fx-line-spacing:2;"/>

                            <!-- Solution SOLDE -->
                            <VBox fx:id="panelSolutionSolde" spacing="5"
                                  visible="false" managed="false"
                                  style="-fx-background-color:#F0FDF4;
                                         -fx-border-color:#BBF7D0;
                                         -fx-border-radius:10; -fx-background-radius:10;
                                         -fx-padding:10 14;">
                                <HBox spacing="7" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-chart-line"
                                              style="-fx-fill:#009485; -fx-icon-size:12;"/>
                                    <Label text="CONDITION SOLDE — Que faire ?"
                                           style="-fx-font-size:11px; -fx-font-weight:800;
                                                  -fx-text-fill:#065F46;"/>
                                </HBox>
                                <Label fx:id="lblSolutionSolde" text="" wrapText="true"
                                       style="-fx-font-size:11px; -fx-text-fill:#374151;
                                              -fx-padding:0 0 0 4;"/>
                            </VBox>

                            <!-- Solution BUDGET -->
                            <VBox fx:id="panelSolutionBudget" spacing="5"
                                  visible="false" managed="false"
                                  style="-fx-background-color:#FFFBEB;
                                         -fx-border-color:#FDE68A;
                                         -fx-border-radius:10; -fx-background-radius:10;
                                         -fx-padding:10 14;">
                                <HBox spacing="7" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-wallet"
                                              style="-fx-fill:#D4A82A; -fx-icon-size:12;"/>
                                    <Label text="CONDITION BUDGET — Que faire ?"
                                           style="-fx-font-size:11px; -fx-font-weight:800;
                                                  -fx-text-fill:#92400E;"/>
                                </HBox>
                                <Label fx:id="lblSolutionBudget" text="" wrapText="true"
                                       style="-fx-font-size:11px; -fx-text-fill:#374151;
                                              -fx-padding:0 0 0 4;"/>
                            </VBox>

                            <!-- Solution ÉPARGNE -->
                            <VBox fx:id="panelSolutionEpargne" spacing="5"
                                  visible="false" managed="false"
                                  style="-fx-background-color:#F0FDFB;
                                         -fx-border-color:#99F6E4;
                                         -fx-border-radius:10; -fx-background-radius:10;
                                         -fx-padding:10 14;">
                                <HBox spacing="7" alignment="CENTER_LEFT">
                                    <FontIcon iconLiteral="fas-piggy-bank"
                                              style="-fx-fill:#009485; -fx-icon-size:12;"/>
                                    <Label text="CONDITION ÉPARGNE — Que faire maintenant ?"
                                           style="-fx-font-size:11px; -fx-font-weight:800;
                                                  -fx-text-fill:#065F46;"/>
                                </HBox>
                                <Label fx:id="lblSolutionEpargne" text="" wrapText="true"
                                       style="-fx-font-size:11px; -fx-text-fill:#374151;
                                              -fx-padding:0 0 0 4;"/>
                                <HBox spacing="6" alignment="CENTER_LEFT"
                                      style="-fx-background-color:rgba(0,180,160,0.08);
                                             -fx-background-radius:6; -fx-padding:5 8;">
                                    <FontIcon iconLiteral="fas-magic"
                                              style="-fx-fill:#009485; -fx-icon-size:10;"/>
                                    <Label text="✨ Après avoir ajouté au coffre, clique sur Re-vérifier — la roue s'ouvre automatiquement !"
                                           wrapText="true" HBox.hgrow="ALWAYS"
                                           style="-fx-font-size:10px; -fx-text-fill:#0D7377;
                                                  -fx-font-style:italic;"/>
                                </HBox>
                            </VBox>

                            <HBox spacing="7" alignment="TOP_LEFT">
                                <FontIcon iconLiteral="fas-lightbulb"
                                          style="-fx-fill:#D4A82A; -fx-icon-size:12;"/>
                                <Label fx:id="lblRefusSuggestion" text="" wrapText="true"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-font-size:11px; -fx-text-fill:#92400E;
                                              -fx-font-style:italic;"/>
                            </HBox>

                            <Button fx:id="btnReVerifier"
                                    text="🔄  Re-vérifier mon éligibilité"
                                    onAction="#reVerifierEligibilite"
                                    maxWidth="1.7976931348623157E308"
                                    style="-fx-background-color:linear-gradient(to right,#009485,#00B4A0);
                                           -fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:12px;
                                           -fx-background-radius:20; -fx-padding:10 22; -fx-cursor:hand;
                                           -fx-effect:dropshadow(gaussian,rgba(0,148,133,0.40),10,0.3,0,3);"/>
                        </VBox>

                        <!-- ─── RÈGLES ─────────────────────────────────────── -->
                        <VBox spacing="6"
                              style="-fx-background-color:#FFFFFF;
                                     -fx-border-color:#E5E7EB;
                                     -fx-border-radius:12; -fx-background-radius:12;
                                     -fx-padding:14 16;
                                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.04),6,0,0,1);">
                            <HBox alignment="CENTER_LEFT" spacing="7">
                                <FontIcon iconLiteral="fas-info-circle"
                                          style="-fx-fill:#009485; -fx-icon-size:13;"/>
                                <Label text="Règles du jeu"
                                       style="-fx-font-size:12px; -fx-font-weight:700;
                                              -fx-text-fill:#1F2937;"/>
                            </HBox>
                            <Label text="• 1 tour par mois · Points cumulés mois après mois"
                                   style="-fx-font-size:10px; -fx-text-fill:#6B7280;"/>
                            <Label text="• 25 pts → Cashback · 50 pts → Réduction frais bancaires"
                                   style="-fx-font-size:10px; -fx-text-fill:#6B7280;"/>
                            <Label text="• 100 pts → 🎁 +50 DT crédités automatiquement !"
                                   style="-fx-font-size:10px; -fx-font-weight:700;
                                          -fx-text-fill:#D4A82A;"/>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </VBox>
        </HBox>
    </VBox>
</StackPane>
